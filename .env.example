# Database
DATABASE_URL=postgresql://lis_user:lis_password@localhost:5432/lis_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# App
API_PORT=4000
WEB_PORT=3000
NODE_ENV=development

# Public / LAN access (replace with your server IP or domain)
PUBLIC_HOST=142.132.189.60
WEB_URL=http://142.132.189.60:3000
NEXT_PUBLIC_API_URL=http://142.132.189.60:4000
# API listens on all interfaces (required for remote access)
API_HOST=0.0.0.0
# Extra allowed browser origins (comma-separated), e.g. http://142.132.189.60:3000,http://localhost:3000
CORS_ORIGINS=http://142.132.189.60:3000,http://localhost:3000
# Docker only: internal API URL for Next.js server-side rewrites (browser uses NEXT_PUBLIC_API_URL)
# API_INTERNAL_URL=http://api:4000

# Prisma migrations (dual strategy — see README "Database migrations")
# development | staging | production — blocks unsafe dev-only flows when staging/production
DATABASE_ENV=development

# prisma migrate reset (dev only): required to allow destructive reset
# PRISMA_RESET_CONFIRM=1
# Optional override if DATABASE_URL is not localhost but DB is still disposable
# PRISMA_RESET_FORCE=1

# Zebra Browser Print (optional). If you trust SSL only on one host, set it explicitly, e.g.:
# NEXT_PUBLIC_ZEBRA_AGENT_ORIGIN=https://localhost:9101

# Device Result Ingestion (helper app)
# Production: set a strong random secret; helper sends X-Device-Api-Key and X-Lab-Id.
DEVICE_API_KEY=change-me-to-a-strong-random-secret
#
# Dev shortcut (INSECURE — do not use in production):
#   DEVICE_INGEST_AUTH_DISABLED=1  → skip API key check
#   INGEST_DEFAULT_LAB_ID=<uuid>   → skip X-Lab-Id if also not sending body.laboratoryId
# To re-enable strict auth: unset DEVICE_INGEST_AUTH_DISABLED, set INGEST=0, require headers.
# DEVICE_INGEST_AUTH_DISABLED=0
# INGEST_DEFAULT_LAB_ID=

# Puppeteer / Chromium (used by whatsapp-web.js)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# WhatsApp Web.js (sessions must live outside Git — use Docker volume or secure path)
# WHATSAPP_ENABLED=1               # default in dev | set 0 on API replicas that must not launch Chromium
# WHATSAPP_AUTH_DATA_PATH=.wwebjs_auth   # overrides default under process.cwd()
# WHATSAPP_SESSION_ID=             # optional clientId for multiple isolated sessions on one host

# API container: skip DB migrate on boot if you run migrations in CI / K8s Job
# RUN_MIGRATIONS_ON_BOOT=1

# Tests / CI: disable strict env validation (do not use in production)
# SKIP_ENV_VALIDATION=1
