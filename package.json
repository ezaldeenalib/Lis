{
  "name": "@lis/source",
  "version": "1.0.0",
  "private": true,
  "description": "LIS SaaS Platform - Laboratory Information System",
  "scripts": {
    "dev:api": "nest build && node dist/apps/api/main.js",
    "dev:web": "node node_modules/next/dist/bin/next dev apps/web",
    "build:shared": "tsc -p libs/shared/tsconfig.json",
    "build:api": "nest build",
    "build:web": "next build apps/web",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "db:generate": "prisma generate --schema=libs/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=libs/database/prisma/schema.prisma",
    "db:migrate:prod": "node scripts/prisma-migration.cjs guard-deploy",
    "db:migrate:deploy": "node scripts/prisma-migration.cjs guard-deploy",
    "db:migrate:new": "node scripts/prisma-migration.cjs migrate-new",
    "db:migrate:diff": "node scripts/prisma-migration.cjs diff",
    "db:migrate:guard-dev-append": "node scripts/prisma-migration.cjs guard-dev-append",
    "db:migrate:reset": "node scripts/prisma-migration.cjs guard-reset",
    "db:migrate:status": "node scripts/prisma-migration.cjs status",
    "db:seed": "ts-node libs/database/prisma/seed.ts",
    "db:studio": "prisma studio --schema=libs/database/prisma/schema.prisma",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prepare": "prisma generate --schema=libs/database/prisma/schema.prisma"
  },
